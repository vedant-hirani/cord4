# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URI=mongodb://localhost:27017/cord4

# Security & JWT Configuration
JWT_SECRET=your_jwt_access_secret_key_change_me_in_production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_me_in_production
JWT_REFRESH_EXPIRES_IN=7d

# Third-party Integrations
GROK_API_KEY=your_grok_xai_api_key_here

# AWS Configuration (Placeholders)
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_s3_bucket_name
AWS_REGION=us-east-1

# Redis Configuration (Placeholders)
REDIS_URL=redis://localhost:6379

# Firebase Configuration (Placeholders)
FIREBASE_SENDER_ID=your_firebase_sender_id
FIREBASE_SERVER_KEY=your_firebase_server_key

# SMTP Configuration (Placeholders)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=no-reply@cord4backend.com

# Twilio Configuration (Placeholders)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
