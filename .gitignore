bower_components

# node-gyp compilation folder (https://github.com/nodejs/node-gyp)
build/dev-bundle

# Dependency directories (https://docs.npmjs.com/cli/configuring-npm/package-json#directories)
doc/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

