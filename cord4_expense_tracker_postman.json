    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response && response.success && response.data && response.data.tokens) {",
                  "    pm.collectionVariables.set(\"auth_token\", response.data.tokens.accessToken);",
                  "    pm.collectionVariables.set(\"refresh_token\", response.data.tokens.refreshToken);",
                  "    console.log(\"Register: Auth tokens stored in collection variables successfully!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Vedant Hirani\",\n  \"email\": \"vedant.hirani@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Creates a new user profile and returns access and refresh JWT pairs."
          },
          "response": []
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response && response.success && response.data && response.data.tokens) {",
                  "    pm.collectionVariables.set(\"auth_token\", response.data.tokens.accessToken);",
                  "    pm.collectionVariables.set(\"refresh_token\", response.data.tokens.refreshToken);",
                  "    console.log(\"Login: Auth tokens stored in collection variables successfully!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"vedant.hirani@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Authenticates credentials and issues a JWT token. Automatically saves access and refresh tokens in postman variables."
          },
          "response": []
