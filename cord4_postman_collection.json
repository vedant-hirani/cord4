            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Updated\",\n  \"email\": \"john.updated@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "users",
                "me"
              ]
            },
            "description": "Updates profile fields such as name or email for the logged-in user."
          },
          "response": []
        },
        {
          "name": "Change My Password",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{auth_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"SecurePass123!\",\n  \"newPassword\": \"NewSecurePass567!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/change-password",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "users",
                "change-password"
              ]
            },
            "description": "Modifies the authenticated user's password. Securely hashes and stores the new key."
          },
          "response": []
        },
        {
          "name": "List All Users (Admin/Manager Only)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{auth_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/users/list?page=1&limit=10&search=john",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "users",
                "list"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "search",
                  "value": "john"
                }
              ]
            },
            "description": "Retrieves a paginated list of all users, searchable by name and email. Restricts access exclusively to Admin and Manager roles."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Send System Notification",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{auth_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"phone\": \"+1234567890\",\n  \"fcmToken\": \"fcm_device_token_placeholder\",\n  \"channels\": [\"email\", \"sms\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/notifications/send",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "notifications",
